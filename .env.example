# Get this from build.nvidia.com - sign in, open a model page, "Get API Key"
NVIDIA_API_KEY=nvapi-...

# Fine-grained PAT scoped ONLY to your test repo (Issues + PRs + Contents + Metadata, read/write)
# GitHub -> Settings -> Developer settings -> Personal access tokens -> Fine-grained tokens
GITHUB_TOKEN=github_pat_...

# owner/repo of your disposable test repository - NOT a repo you care about,
# the agent will create/comment/label real issues on it
GITHUB_REPO=yourusername/watermelon-test-agent

# LLM model for planning and code synthesis.
# Verified active on integrate.api.nvidia.com as of June 2026.
# If you get 404s, confirm on build.nvidia.com that the model is still listed.
NIM_MODEL_ID=meta/llama-3.1-70b-instruct

# Embedding model for semantic similarity (memory plan-reuse and duplicate detection).
# Verified active on integrate.api.nvidia.com as of June 2026.
# input_type=query is already sent in src/memory/embeddings.py - no changes needed.
# Without this set, plan reuse falls back to TF-IDF (lexical only, not semantic).
NIM_EMBEDDING_MODEL_ID=nvidia/nv-embedqa-e5-v5
